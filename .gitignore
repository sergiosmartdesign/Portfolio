# Archivos de dependencias
# No subas las dependencias directamente, deben ser instaladas por el gestor de paquetes.
node_modules/

# Archivos de entorno
# Contienen variables de entorno y secretos. ¡Nunca los subas a un repositorio público!
.env
.env.local
.env.*.local

# Archivos de registro (logs)
# Suelen contener información sensible o de depuración que no es relevante para otros desarrolladores.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Directorios de compilación y artefactos
# Estos archivos son generados automáticamente durante el proceso de build.
dist/
build/
.out/

# Reportes de cobertura de pruebas
coverage/

# Archivos específicos del sistema operativo
.DS_Store
Thumbs.db

# Archivos de configuración de editores de código
# Cada desarrollador puede tener su propia configuración.
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Archivos temporales
*.tmp
*.swp